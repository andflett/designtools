  "dependencies": {
    "@designtools/vite-plugin": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "tsup": "^8.0.0",
    "vite": "^6.0.0"
  }
}
