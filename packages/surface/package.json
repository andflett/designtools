{
  "name": "@designtools/surface",
  "version": "0.1.23",
  "description": "Visual editing CLI — hybrid architecture with selection overlays in the target app and editor UI served separately",
  "type": "module",
  "license": "CC-BY-NC-4.0",
  "author": "Andrew Flett",
  "repository": {
    "type": "git",
    "url": "https://github.com/andflett/designtools"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:client": "vite dev src/client",
    "build": "vite build && tsup",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"const p=require('path'),f=require('fs');const h=p.join(p.dirname(require.resolve('node-pty/package.json')),'prebuilds',process.platform+'-'+process.arch,'spawn-helper');try{f.chmodSync(h,'755');}catch(e){}\""
  },
  "bin": {
    "surface": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@astrojs/compiler": "^2.10.0",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^6.0.116",
    "ast-types": "^0.14.2",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "express": "^5.1.0",
    "lucide-react": "^0.575.0",
    "nanoid": "^3.3.11",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.0.0",
    "recast": "^0.23.9",
    "shiki": "^3.23.0",
    "streamdown": "^2.4.0",
    "tailwindcss": "^4.1.0",
    "use-stick-to-bottom": "^1.1.3",
    "vite": "^6.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
